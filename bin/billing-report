#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';

use PaperclipBilling\BillingReportGenerator;
use PaperclipBilling\PaperclipClient;
use Symfony\Component\Console\Application;
use Symfony\Component\Console\Command\Command;
use Symfony\Component\Console\Input\InputInterface;
use Symfony\Component\Console\Input\InputOption;
use Symfony\Component\Console\Output\OutputInterface;
use Symfony\Component\Console\Helper\Table;

// Load .env if present
$envFile = __DIR__ . '/../.env';
if (file_exists($envFile)) {
    $lines = file($envFile, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    foreach ($lines as $line) {
        if (str_starts_with(trim($line), '#')) {
            continue;
        }
        if (str_contains($line, '=')) {
            putenv(trim($line));
        }
    }
}

$app = new Application('Paperclip Billing Tracker', '1.0.0');

$command = new class extends Command {
    protected function configure(): void
    {
        $this
            ->setName('report')
            ->setDescription('Generate a time tracking billing report from Paperclip')
            ->addOption('api-url', null, InputOption::VALUE_REQUIRED, 'Paperclip API URL', getenv('PAPERCLIP_API_URL') ?: null)
            ->addOption('api-key', null, InputOption::VALUE_REQUIRED, 'Paperclip API key', getenv('PAPERCLIP_API_KEY') ?: null)
            ->addOption('company-id', null, InputOption::VALUE_REQUIRED, 'Company ID', getenv('PAPERCLIP_COMPANY_ID') ?: null)
            ->addOption('status', null, InputOption::VALUE_REQUIRED, 'Filter by issue status (comma-separated)', null)
            ->addOption('json', null, InputOption::VALUE_NONE, 'Output as JSON');
    }

    protected function execute(InputInterface $input, OutputInterface $output): int
    {
        $apiUrl = $input->getOption('api-url');
        $apiKey = $input->getOption('api-key');
        $companyId = $input->getOption('company-id');

        if (!$apiUrl || !$apiKey || !$companyId) {
            $output->writeln('<error>Missing required options. Set PAPERCLIP_API_URL, PAPERCLIP_API_KEY, PAPERCLIP_COMPANY_ID env vars or pass --api-url, --api-key, --company-id.</error>');
            return Command::FAILURE;
        }

        $output->writeln('<info>Fetching data from Paperclip API...</info>');

        try {
            $client = new PaperclipClient($apiUrl, $apiKey, $companyId);
            $generator = new BillingReportGenerator($client);
            $report = $generator->generate($input->getOption('status'));
        } catch (\Throwable $e) {
            $output->writeln('<error>Failed: ' . $e->getMessage() . '</error>');
            return Command::FAILURE;
        }

        if ($input->getOption('json')) {
            $output->writeln(json_encode($report, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES));
            return Command::SUCCESS;
        }

        $output->writeln('');
        $output->writeln("<info>Billing Report — Company: {$report['companyId']}</info>");
        $output->writeln("<info>Generated: {$report['generatedAt']}</info>");
        $output->writeln('');

        foreach ($report['lines'] as $line) {
            $table = new Table($output);
            $table->setHeaders(['Project', 'Billing Code', 'Total Minutes', 'Tasks']);
            $table->addRow([
                $line['projectName'] ?? $line['projectId'] ?? '(none)',
                $line['billingCode'] ?? '(none)',
                number_format($line['totalMinutes'], 2),
                $line['taskCount'],
            ]);
            $table->render();

            if (!empty($line['agentBreakdown'])) {
                $agentTable = new Table($output);
                $agentTable->setHeaders(['  Agent', '  Minutes', '  Tasks']);
                foreach ($line['agentBreakdown'] as $agent) {
                    $agentTable->addRow([
                        '  ' . $agent['agentName'],
                        '  ' . number_format($agent['totalMinutes'], 2),
                        '  ' . $agent['taskCount'],
                    ]);
                }
                $agentTable->render();
            }

            $output->writeln('');
        }

        $output->writeln("<info>Grand Total: {$report['grandTotalMinutes']} minutes across {$report['grandTotalTasks']} tasks</info>");

        return Command::SUCCESS;
    }
};

$app->add($command);
$app->setDefaultCommand('report', true);
$app->run();
